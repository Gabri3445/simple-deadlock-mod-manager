{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "height": 900,
        "minHeight": 500,
        "minWidth": 800,
        "title": "deadlock-mod-manager",
        "width": 1600
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "rimraf src/generated & pnpm build",
    "beforeDevCommand": "rimraf src/generated & pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "identifier": "com.deadlock-mod-manager.app",
  "plugins": {
    "typegen": {
      "excludePatterns": null,
      "force": false,
      "includePatterns": null,
      "includePrivate": false,
      "outputPath": "../src/generated",
      "projectPath": ".",
      "typeMappings": null,
      "validationLibrary": "zod",
      "verbose": false,
      "visualizeDeps": false
    }
  },
  "productName": "deadlock-mod-manager",
  "version": "0.1.0"
}